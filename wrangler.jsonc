{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "student-emotion-coach",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-24",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "html_handling": "auto-trailing-slash",
    "run_worker_first": ["/api/*"]
  },
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "observability": {
    "enabled": true
  }
}
